{
  "workspace": ["./services/*", "./integrations/*"],
  "nodeModulesDir": "auto",
  "imports": {
    "@solana-program/system": "npm:@solana-program/system@^0.12.0",
    "@solana/kit": "npm:@solana/kit@^6.5.0",
    "discordeno": "npm:discordeno@^21.0.0",
    "effect": "npm:effect@^3.21.0",
    "oxlint": "npm:oxlint@^1.57.0"
  },
  "tasks": {
    "prod": "deno --env -A main.ts",
    "discord-bot": "deno --env -A ./integrations/discord/client.ts",
    "lint": "deno run -A npm:oxlint@latest --type-aware",
    "cache-lint": "deno cache npm:oxlint@latest npm:oxlint-tsgolint@latest"
  },
  "fmt": {
    "useTabs": false,
    "indentWidth": 4
  }
}
